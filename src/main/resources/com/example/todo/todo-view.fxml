<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.todo.TodoController"
           prefWidth="700.0"
           prefHeight="450.0">

    <BorderPane fx:id="mainContent" styleClass="app-root">

        <top>
            <VBox spacing="10.0" BorderPane.alignment="CENTER">
                <padding>
                    <Insets top="16" right="16" bottom="10" left="16"/>
                </padding>

                <Label fx:id="titleLabel" text="Todo List Demo" styleClass="title-text"/>
                <Label fx:id="greetingLabel" text="Welcome!" styleClass="greeting-label"/>

                <HBox spacing="8.0" alignment="CENTER_LEFT">
                    <Label text="List:"/>
                    <ComboBox fx:id="listSelector" prefWidth="220.0"/>
                    <Button fx:id="newListButton" text="New List" onAction="#onCreateNewList"/>
                </HBox>

                <HBox spacing="8.0" alignment="CENTER_LEFT">
                    <TextField fx:id="taskInput"
                               HBox.hgrow="ALWAYS"
                               promptText="Type a new task and press Add"/>
                    <Button fx:id="addButton" text="Add" onAction="#onAddTask"/>
                </HBox>

                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <Label text="Font Size"/>
                    <Slider fx:id="fontSizeSlider" min="12.0" max="42.0" value="22.0" prefWidth="170.0"/>
                    <Label fx:id="fontSizeValueLabel" text="Todo text: 22 px" styleClass="preview-label"/>
                </HBox>
            </VBox>
        </top>

        <center>
            <VBox fx:id="todoCard" styleClass="card-view" BorderPane.alignment="CENTER">
                <BorderPane.margin>
                    <Insets right="16" left="16"/>
                </BorderPane.margin>
                <ListView fx:id="taskListView" styleClass="task-list" VBox.vgrow="ALWAYS"/>
            </VBox>
        </center>

        <bottom>
            <HBox spacing="8.0" alignment="CENTER_LEFT" BorderPane.alignment="CENTER">
                <padding>
                    <Insets top="10" right="16" bottom="16" left="16"/>
                </padding>

                <Button fx:id="markDoneButton" text="Toggle Done" onAction="#onToggleDone"/>
                <Button fx:id="removeButton" text="Remove Selected" onAction="#onRemoveTask"/>
                <Button fx:id="clearDoneButton" text="Clear Done" onAction="#onClearDone"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="counterLabel" styleClass="counter-label" text="Active: 0 | Done: 0"/>
            </HBox>
        </bottom>
    </BorderPane>

    <StackPane fx:id="popupOverlay" visible="false" managed="false" styleClass="popup-overlay">
        <VBox spacing="10.0" maxWidth="320.0" styleClass="popup-card">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <Label text="Create New Todo List" styleClass="popup-title"/>
            <TextField fx:id="newListNameInput" promptText="List name"/>

            <HBox spacing="8.0" alignment="CENTER_RIGHT">
                <Button text="Cancel" onAction="#onCancelCreateNewList"/>
                <Button text="Create" defaultButton="true" onAction="#onConfirmCreateNewList"/>
            </HBox>
        </VBox>
    </StackPane>
</StackPane>
